# Video Content Extractor — Environment Configuration
# Copy this file to .env and fill in your values, or configure via config.json directly.
# cp .env.example .env

# === AI API (Required for summarization) ===
# Supports any OpenAI-compatible API endpoint (DeepSeek, OpenAI, GLM, etc.)
AI_API_KEY=YOUR_API_KEY_HERE
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# === Alternative API examples ===
# DeepSeek:      AI_BASE_URL=https://api.deepseek.com/v1          AI_MODEL=deepseek-chat
# OpenAI:        AI_BASE_URL=https://api.openai.com/v1            AI_MODEL=gpt-4o
# Zhipu GLM:     AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4 AI_MODEL=glm-4
# SenseNova:     AI_BASE_URL=https://token.sensenova.cn/v1        AI_MODEL=deepseek-v4-flash

# === Output ===
OUTPUT_DIR=./output
OUTPUT_FORMAT=markdown

# === Transcription (Optional) ===
TRANSCRIBE_ENABLED=false
TRANSCRIBE_METHOD=auto
WHISPER_MODEL=base
WHISPER_LANGUAGE=zh

# === Transcription API (Optional — only if using cloud ASR) ===
# Used by processors/transcriber.py when method=api
TRANSCRIBE_API_KEY=YOUR_TRANSCRIBE_API_KEY_HERE
